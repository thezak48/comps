{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    }
  ],
  "dependencyDashboard": true,
  "schedule": ["every weekend"],
  "labels": ["dependencies"],
  "branchPrefix": "deps/",
  "commitMessagePrefix": "chore(deps): ",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "stabilityDays": 3
}
