{
  "openapi": "3.1.0",
  "info": {
    "title": "Comps API",
    "description": "API for creating and managing image comparisons",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/comparisons": {
      "get": {
        "tags": [
          "api"
        ],
        "summary": "List Comparisons",
        "description": "List all available comparisons.\n\nReturns a list of all comparisons with their basic metadata including:\n- ID, name, and show name\n- Tags\n- Grid dimensions (rows and columns)\n- Expiration settings\n- Creation and last accessed timestamps",
        "operationId": "list_comparisons_api_v1_comparisons_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ComparisonResponse"
                  },
                  "type": "array",
                  "title": "Response List Comparisons Api V1 Comparisons Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "api"
        ],
        "summary": "Create New Comparison",
        "description": "Create a new comparison.\n\nCreates a new comparison with the specified parameters:\n- Name and show name (optional)\n- Tags for categorization (optional)\n- Grid dimensions (rows and columns)\n- Expiration settings\n\nReturns the created comparison with its assigned ID and timestamps.\n\nThe comparison will be empty initially and images can be added later.",
        "operationId": "create_new_comparison_api_v1_comparisons_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ComparisonCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ComparisonResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/comparisons/{comparison_id}": {
      "get": {
        "tags": [
          "api"
        ],
        "summary": "Get Comparison Detail",
        "description": "Get detailed information about a specific comparison.\n\nReturns comprehensive information about the comparison including:\n- Basic metadata (ID, name, show name, tags)\n- Grid dimensions (rows and columns)\n- Expiration settings\n- Creation and last accessed timestamps\n- Complete list of images with their positions and metadata\n\nThis endpoint also updates the last_accessed timestamp for the comparison.",
        "operationId": "get_comparison_detail_api_v1_comparisons__comparison_id__get",
        "parameters": [
          {
            "name": "comparison_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Comparison Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ComparisonDetail"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/comparisons/{comparison_id}/images": {
      "post": {
        "tags": [
          "api"
        ],
        "summary": "Upload Images",
        "description": "Upload images to an existing comparison.\n\nUpload one or more image files to a comparison and specify their positions in the grid.\n\n- Files should be image files (jpg, jpeg, png, bmp, webp)\n- Positions can be specified as a JSON string mapping filenames to grid positions\n\nExample positions JSON:\n```json\n{\n    \"image1.jpg\": {\"row\": 0, \"column\": 0},\n    \"image2.jpg\": {\"row\": 0, \"column\": 1}\n}\n```",
        "operationId": "upload_images_api_v1_comparisons__comparison_id__images_post",
        "parameters": [
          {
            "name": "comparison_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Comparison Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_images_api_v1_comparisons__comparison_id__images_post"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/comparisons/{comparison_id}/images/{filename}": {
      "put": {
        "tags": [
          "api"
        ],
        "summary": "Update Image Metadata",
        "description": "Update image metadata.\n\nCurrently supports updating:\n- Custom name for the image\n\nThe custom name can be used to provide a more descriptive label for the image\nthat will be displayed in the UI.",
        "operationId": "update_image_metadata_api_v1_comparisons__comparison_id__images__filename__put",
        "parameters": [
          {
            "name": "comparison_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Comparison Id"
            }
          },
          {
            "name": "filename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Filename"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomNameUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Health check endpoint for monitoring",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Home",
        "description": "Render the home page with upload form.",
        "operationId": "home__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
