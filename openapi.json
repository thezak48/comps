          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tags",
            "description": "List of tags for categorizing the comparison",
            "examples": [
              [
                "example",
                "test",
                "api"
              ]
            ]
          },
          "total_rows": {
            "type": "integer",
            "title": "Total Rows",
            "description": "Number of rows in the comparison grid",
            "default": 1,
            "examples": [
              1
            ]
          },
          "total_columns": {
            "type": "integer",
            "title": "Total Columns",
            "description": "Number of columns in the comparison grid",
            "default": 2,
            "examples": [
              2
            ]
          },
          "expiration_type": {
            "type": "string",
            "title": "Expiration Type",
            "description": "When to expire the comparison: 'from_creation' or 'from_last_access'",
            "default": "from_last_access",
            "examples": [
              "from_last_access"
            ]
          },
          "expiration_days": {
            "type": "integer",
            "title": "Expiration Days",
            "description": "Number of days until the comparison expires",
            "default": 7,
            "examples": [
              7
            ]
          }
        },
        "type": "object",
        "title": "ComparisonCreate"
