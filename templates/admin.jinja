{% extends "base.jinja" %}

{% block title %}Admin | Comps{% endblock %}

{% block content %}
<div class="container">
    <div class="admin-container">
        <h2 class="mb-4 text-light">Admin Panel</h2>
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Invitation Codes</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/admin/create-invitation" class="mb-4">
                    <button type="submit" class="btn btn-primary bg-primary">
                        <i class="fa fa-plus"></i> Generate New Invitation Code
                    </button>
                </form>
                <h6>Your Invitation Codes:</h6>
                <table class="table table-dark">
                    <thead>
                    <tr>
                        <th>Code</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Used By</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for code in invitation_codes %}
                    <tr>
                        <td><code>{{ code.code }}</code></td>
                        <td>
                            {% if code.is_used %}
                            <span class="badge bg-success">Used</span>
                            {% else %}
                            <span class="badge bg-secondary">Unused</span>
                            {% endif %}
                        </td>
                        <td>{{ code.created_at.split(' ')[0] }}</td>
                        <td>{{ code.used_by or 'N/A' }}</td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% if user.is_super_admin %}
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">User Management</h5>
            </div>
            <div class="card-body">
                <table class="table table-dark">
                    <thead>
                    <tr>
                        <th>Username</th>
                        <th>Is Admin</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for u in all_users %}
                    <tr>
                        <td>
                            {{ u.username }} {% if u.is_super_admin %}<span
                                class="badge bg-danger"
                        >
                  Super Admin </span
                        >{% endif %}
                        </td>
                        <td>
                            {% if u.is_admin %}
                            <span class="badge bg-info">Admin</span>
                            {% else %}
                            <span class="badge bg-secondary">User</span>
                            {% endif %}
                        </td>
                        <td>{{ u.created_at.split(' ')[0] }}</td>
                        <td>
                            {% if not u.is_super_admin %}
                            <div class="form-check form-switch">
                                <input
                                        class="form-check-input"
                                        type="checkbox"
                                        role="switch"
                                        id="adminSwitch{{ u.id }}"
                                        {%
                                        if
                                        u.is_admin
                                        %}checked{%
                                        endif
                                        %}
                                        onchange="toggleAdmin({{ u.id }}, this.checked)"
                                />
                                <label class="form-check-label" for="adminSwitch{{ u.id }}">
                                    Set Admin
                                </label>
                            </div>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}
    </div>
</div>

{% if user.is_super_admin %}
<script>
    async function toggleAdmin(userId, isAdmin) {
      try {
        const response = await fetch("/admin/user/set-admin", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            user_id: userId,
            is_admin: isAdmin,
          }),
          redirect: "manual", // Prevent fetch from following the redirect automatically
        });

        // After the request, reload the page to show the updated status
        window.location.reload();
      } catch (error) {
        console.error("Error updating admin status:", error);
        alert("An error occurred while updating admin status.");
      }
    }
</script>
{% endif %}
{% endblock %}
