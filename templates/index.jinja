{% extends "base.jinja" %}

{% block title %}Image Comparison | Comps{% endblock %}

{% block content %}
<div class="container">
    <div class="metadata-form">
        <div class="form-row">
            <div class="form-group main-field">
                <label for="comparison-name">Comparison Name:</label>
                <input
                        type="text"
                        id="comparison-name"
                        placeholder="Enter a name for this comparison"
                />
            </div>
            <div class="optional-fields">
                <div class="form-check">
                    <input type="checkbox" id="show-name-toggle" class="form-check-input"/>
                    <label for="show-name-toggle" class="form-check-label"
                    >Add Show/Film Name</label
                    >
                </div>
                <div class="form-check">
                    <input type="checkbox" id="tags-toggle" class="form-check-input"/>
                    <label for="tags-toggle" class="form-check-label">Add Tags</label>
                </div>
                <div class="form-check">
                    <input
                            type="checkbox"
                            id="expiration-toggle"
                            class="form-check-input"
                    />
                    <label
                            for="expiration-toggle"
                            class="form-check-label"
                            data-bs-toggle="tooltip"
                            data-bs-placement="top"
                            title="{% if user %}By default, your comparisons never expire. Check this to set an expiration.{% else %}If unchecked, files will be deleted after 7 days of inactivity{% endif %}"
                    >Set Expiration<i class="fa fa-question-circle ms-1 fa-xs"></i
                    ></label>
                </div>
            </div>
        </div>
        <div
                class="form-group hidden-field"
                id="show-name-container"
                style="display: none"
        >
            <label for="show-name">Show/Film Name:</label>
            <input type="text" id="show-name" placeholder="Enter show or film name"/>
        </div>
        <div
                class="form-group hidden-field"
                id="tags-container"
                style="display: none"
        >
            <label for="tags">Tags:</label>
            <input type="text" id="tags" placeholder="Enter tags separated by commas"/>
        </div>
        <div
                class="form-group hidden-field"
                id="expiration-container"
                style="display: none"
        >
            <label>Expiration Settings:</label>
            <div class="expiration-options">
                <div class="form-check">
                    <input
                            type="radio"
                            id="expiration-last-access"
                            name="expiration-type"
                            value="from_last_access"
                            class="form-check-input"
                            checked
                    />
                    <label for="expiration-last-access" class="form-check-label"
                    >Delete after inactive for</label
                    >
                </div>
                <div class="form-check">
                    <input
                            type="radio"
                            id="expiration-creation"
                            name="expiration-type"
                            value="from_creation"
                            class="form-check-input"
                    />
                    <label for="expiration-creation" class="form-check-label"
                    >Delete after created for</label
                    >
                </div>
                <div class="expiration-days-container">
                    <select id="expiration-days" class="form-select">
                        <option value="1">1 day</option>
                        <option value="7" selected>7 days</option>
                        <option value="30">30 days</option>
                        <option value="90">90 days</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
    <div class="upload-area w-100 upload-instructions" id="dropZone">
        <p>Select images to be uploaded for side-by-side comparison.</p>
        <p>
            You can upload images with any file name - they'll be arranged in columns
            automatically.
        </p>
        <p>
            <strong>Naming Pattern (Optional):</strong> If you use the pattern
            <code>first0001.png</code>, <code>second0001.png</code>, etc., files will be
            grouped by their number with columns based on the prefix.
        </p>
        <p>
            Otherwise, files will be arranged sequentially in the order they're
            uploaded.
        </p>
        <p>Drag and drop images here or click to select files</p>
        <input
                type="file"
                id="fileInput"
                multiple
                accept="image/*"
                style="display: none"
        />
    </div>
    <div class="column-management d-flex">
        <button id="add-row-btn" class="btn btn-secondary mb-3 me-2" onclick="addRow()">
            <i class="fas fa-plus"></i> Add Comparison <i class="fa fa-arrow-down"></i>
        </button>
        <button
                id="add-column-btn"
                class="btn btn-secondary mb-3 me-2"
                onclick="addColumn()"
        >
            <i class="fas fa-plus"></i> Add Column <i class="fa fa-arrow-right"></i>
        </button>
    </div>
    <div id="preview">
        <!-- Preview content will be generated dynamically -->
    </div>
    <button id="upload-button" class="btn btn-primary">
        <i class="fa fa-compare"></i> Compare Images
    </button>
</div>
<script src="/static/js/upload.js"></script>
{% endblock %}
